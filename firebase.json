{
  "hosting": {
    "public": "docs",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      { "source": "**/*.html", "headers": [{"key": "Cache-Control", "value": "no-cache, must-revalidate"}] },
      { "source": "**/*.png",  "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}] }
    ]
  }
}
